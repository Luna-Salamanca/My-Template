{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts --target=node --outfile=dist/index.js",
    "dev": "bun run --watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/openapi": "^1.4.14",
    "@repo/shared": "workspace:*",
    "@sinclair/typebox": "^0.34.48",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.25",
    "ioredis": "^5.9.3",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.0",
    "drizzle-kit": "^0.31.9",
    "jose": "^6.1.3"
  }
}
