{
  "name": "monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --build",
    "build": "bun run --filter '*' build",
    "start": "bun run --env-file .env --filter @repo/api start",
    "test": "bun test",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down",
    "docker:rebuild": "docker compose up -d --build --wait"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "typescript": "^5.9.3"
  }
}
