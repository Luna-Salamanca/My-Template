# Database & Redis (Docker hosts: 'postgres' / 'redis')
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/appdb
REDIS_URL=redis://redis:6379

# Auth Secrets
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Discord OAuth & Bot
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_INVITE_URL=

# Role Access (Comma-separated IDs)
ADMIN_ROLE_IDS=
MEMBER_ROLE_IDS=

# Application Environment
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000
VITE_DISCORD_SERVER_NAME=My Discord Server
